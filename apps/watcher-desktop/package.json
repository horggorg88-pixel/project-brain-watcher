{
  "name": "@project-brain/watcher-desktop",
  "version": "1.4.78",
  "description": "Desktop control panel for Project Brain Watcher service",
  "author": "Project Brain",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron dist/main.js",
    "dist": "npm run build && electron-builder --win nsis --x64",
    "test:e2e": "npm run build && playwright test -c playwright.e2e.config.ts"
  },
  "build": {
    "appId": "com.projectbrain.watcher",
    "productName": "Project Brain Watcher",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/index.html",
      "src/app-icon.png",
      "src/app-icon.svg",
      "src/styles.css",
      "src/styles/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ],
      "artifactName": "ProjectBrainWatcher-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "smol-toml": "^1.6.1"
  }
}
